{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gemini",
  "version": "1.0.0",
  "identifier": "com.mustafahasturk.gemini",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data:; script-src 'self' 'unsafe-inline' https://*.google.com https://*.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.google.com https://*.googleapis.com; frame-src https://gemini.google.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../src/i18n/locales/*.json"
    ],
    "macOS": {
      "entitlements": "Entitlements.macOS.plist",
      "exceptionDomain": "gemini.google.com",
      "frameworks": [],
      "minimumSystemVersion": "10.13"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libappindicator3-1"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libappindicator-gtk3"
        ]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/mustafahasturk/gemini-app/releases/latest/download/updater.json",
        "https://github.com/mustafahasturk/gemini/releases/latest/download/updater.json"
      ],
      "pubkey": "UPDATE_KEY_PLACEHOLDER"
    }
  }
}